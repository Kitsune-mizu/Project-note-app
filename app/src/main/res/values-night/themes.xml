<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DARK MODE THEME (SIMPLIFIED) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <style name="AppTheme" parent="Theme.Material3.Dark.NoActionBar">

        <!-- ================= CORE COLOR SYSTEM ================= -->
        <item name="colorPrimary">@color/color_4_dark</item>
        <item name="colorSecondary">@color/color_3_dark</item>
        <item name="colorSurface">@color/color_2_dark</item>
        <item name="android:colorBackground">@color/color_1_dark</item>

        <!-- ================= CUSTOM COLOR ATTRIBUTES ================= -->
        <item name="color_1">@color/color_1_dark</item>
        <item name="color_2">@color/color_2_dark</item>
        <item name="color_3">@color/color_3_dark</item>
        <item name="color_4">@color/color_4_dark</item>
        <item name="text_color">@color/text_dark</item>

        <!-- ================= ACCENT COLORS ================= -->
        <item name="color_error">@color/color_error_night</item>
        <item name="color_green">@color/color_green_night</item>
        <item name="color_yellow">@color/color_yellow_night</item>
        <item name="color_blue">@color/color_blue_night</item>

        <!-- ================= STATUS BAR ================= -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- ================= NAVIGATION BAR ================= -->
        <item name="android:navigationBarColor">@color/color_1_dark</item>

        <!-- ================= WINDOW ================= -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

    </style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DIALOG -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <style name="RoundedDialog" parent="Theme.Material3.Dark.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowMinWidthMajor">85%</item>
        <item name="android:windowMinWidthMinor">85%</item>
        <item name="colorPrimary">@color/color_4_dark</item>
        <item name="colorAccent">@color/color_4_dark</item>
        <item name="android:backgroundTint">@color/color_2_dark</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BOTTOM SHEET -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <style name="ModernBottomSheetDialog" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/ModernBottomSheetStyle</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="ModernBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShape</item>
        <item name="backgroundTint">@color/color_2_dark</item>
    </style>

    <style name="BottomSheetShape" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
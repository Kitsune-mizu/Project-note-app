<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawable: loading_background
    Deskripsi: Background kotak dialog bergaya 8-bit retro game
    Cocok untuk: loading dialog dengan LottieAnimationView
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Shadow / border terluar (efek pixel shadow kanan-bawah khas 8-bit) -->
    <item
        android:left="6dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A000000" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Layer 2: Border luar tebal (garis hitam tebal khas 8-bit UI border) -->
    <item
        android:bottom="2dp"
        android:left="0dp"
        android:right="6dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/color_1" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Layer 3: Border dalam (highlight warna accent retro) -->
    <item
        android:bottom="4dp"
        android:left="3dp"
        android:right="9dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/color_3" />
            <corners android:radius="3dp" />
            <stroke
                android:width="2dp"
                android:color="?attr/color_blue" />
        </shape>
    </item>

    <!-- Layer 4: Background utama (panel gelap retro) -->
    <item
        android:bottom="7dp"
        android:left="6dp"
        android:right="12dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/color_2" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>
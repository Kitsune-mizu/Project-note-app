<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="?attr/color_1"
                android:endColor="?attr/color_2"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="?attr/color_3"
                android:endColor="?attr/color_4"/>
        </shape>
    </item>

</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Settings Screen (Modern)
    Header card disederhanakan, divider pakai colorOutlineVariant
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        tools:ignore="ExtraText">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/cd_settings_icon"
                app:srcCompat="@drawable/ic_settings"
                app:tint="?attr/text_color" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:fontFamily="@font/linottesemibold"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="?attr/text_color"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/settings_description"
                    android:fontFamily="@font/linottesemibold"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/text_color"
                    android:alpha="0.6"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:alpha="0.08"
            android:background="?attr/text_color" />

        <!-- ── SECTION LABEL: STORAGE & BACKUP ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="4dp"
            android:text="@string/header_backup"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/text_color"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="?attr/color_4"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/color_2"
                android:orientation="vertical">

                <!-- Backup & Pemulihan -->
                <LinearLayout
                    android:id="@+id/layoutBackup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_backup_cloud"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/textLastBackupSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/backup_subtitle_none"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── SECTION LABEL: ACCOUNT ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="4dp"
            android:text="@string/header_account"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/text_color"
            android:textStyle="bold" />

        <!-- ── OPTIONS CARD ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="?attr/color_4"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Profile -->
                <LinearLayout
                    android:id="@+id/layoutProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_profile_icon"
                        app:srcCompat="@drawable/ic_person"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/profile_subtitle"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />
                </LinearLayout>

                <!-- Forgot Password -->
                <LinearLayout
                    android:id="@+id/layoutForgotPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_forgot_password"
                        app:srcCompat="@drawable/ic_lock"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forgot_password_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/forgot_password_subtitle"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />
                </LinearLayout>

                <!-- Notifications (dengan Switch) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_notifications_icon"
                        app:srcCompat="@drawable/ic_notifications"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notifications_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/notifications_subtitle"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb"
                        app:trackTint="@color/switch_track"
                        android:checked="true"
                        android:contentDescription="@string/cd_notifications_toggle" />
                </LinearLayout>

                <!-- Theme Mode -->
                <LinearLayout
                    android:id="@+id/layoutTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_dark_mode_icon"
                        app:srcCompat="@drawable/ic_dark_mode"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dialog_theme_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/textCurrentTheme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/theme_system"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />
                </LinearLayout>

                <!-- Color Theme (Light Mode Only) -->
                <LinearLayout
                    android:id="@+id/layoutColorTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_color_theme_icon"
                        app:srcCompat="@drawable/ic_palette"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/color_theme_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/textCurrentColorTheme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/color_theme_blue"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />
                </LinearLayout>

                <!-- Language — inline agar textCurrentLanguage bisa di-findViewById -->
                <LinearLayout
                    android:id="@+id/layoutLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_language_icon"
                        app:srcCompat="@drawable/ic_language"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/language_title"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />

                        <!-- ID ini dipakai di SettingsFragment.java — WAJIB ADA -->
                        <TextView
                            android:id="@+id/textCurrentLanguage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="@string/language_subtitle"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color"
                            android:drawablePadding="6dp"
                            android:alpha="0.6"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="?attr/text_color" />
                </LinearLayout>

                <!-- Delete Account -->
                <LinearLayout
                    android:id="@+id/layoutDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_delete_account"
                        app:srcCompat="@drawable/ic_delete_account"
                        app:tint="?attr/color_error" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="@string/action_delete_account"
                        android:fontFamily="@font/linottesemibold"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/color_error"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Logout -->
                <LinearLayout
                    android:id="@+id/layoutLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_logout_icon"
                        app:srcCompat="@drawable/ic_logout"
                        app:tint="?attr/color_error" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="@string/logout_button"
                        android:fontFamily="@font/linottesemibold"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/color_error"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Splash Screen - TWO PHASES

    PHASE 1 (Startup): Lottie + Loading + Version
    PHASE 2 (Location Detected): Flag + Greeting

    Flag & greeting will be pre-loaded before transition to ensure smooth display
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_3"
    tools:context=".ui.splash.SplashActivity">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- PHASE 1: STARTUP - Lottie Animation -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/splash_animation" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- PHASE 2: LOCATION DETECTED - Flag + Greeting -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/greetingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Flag Image (will appear first) -->
        <ImageView
            android:id="@+id/imgFlag"
            android:layout_width="200dp"
            android:layout_height="133dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/flag_desc"
            android:scaleType="centerCrop"
            android:visibility="invisible" />

        <!-- Greeting Text (will appear after flag) -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/hello_message"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/text_color"
            android:textStyle="bold"
            android:visibility="invisible" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- BOTTOM BAR: Loading indicator + Version (always visible) -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Loading Dots -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="?attr/color_yellow"
            app:trackColor="?attr/color_2"
            app:trackCornerRadius="4dp"
            app:trackThickness="3dp" />

        <!-- App Version -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/text_color"
            android:alpha="0.6" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Splash Screen (Modern)
    Lottie: lottieAnimationView — DIPERTAHANKAN
    Perubahan:
    - Background gradient dari drawable agar tidak flat
    - Lottie diposisikan di tengah layar secara vertikal
    - App name + tagline ditambahkan di bawah Lottie
    - flagContainer & tvGreeting tetap ada (visibility="gone" seperti semula)
    - Bottom bar: versi app + branding kecil di paling bawah
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_primary"
    tools:context=".ui.splash.SplashActivity"
    tools:ignore="ExtraText">

    <!-- ── LOTTIE SPLASH ANIMATION — DIPERTAHANKAN ── -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintBottom_toTopOf="@id/contentGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/splash_animation" />

    <!-- ── APP NAME + TAGLINE (di bawah Lottie) ── -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lottieAnimationView"
        app:layout_constraintBottom_toTopOf="@id/flagContainer">

        <!-- Nama Aplikasi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/md_theme_light_onPrimary"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <!-- Tagline / Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/splash_tagline"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/md_theme_light_onPrimary"
            android:alpha="0.75"
            android:gravity="center" />

    </LinearLayout>

    <!-- ── FLAG & GREETING CONTAINER (logika tetap sama) ── -->
    <FrameLayout
        android:id="@+id/flagContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contentGroup">

        <!-- Flag Image -->
        <ImageView
            android:id="@+id/imgFlag"
            android:layout_width="150dp"
            android:layout_height="100dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/flag_desc"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Greeting Text -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginTop="110dp"
            android:gravity="center"
            android:paddingTop="24dp"
            android:text="@string/hello_message"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/md_theme_light_onPrimary"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ── BOTTOM BAR: Loading indicator + versi ── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Loading Dots -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressLoading"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/md_theme_light_onPrimary"
            app:trackColor="#40FFFFFF"
            app:trackCornerRadius="4dp"
            app:trackThickness="3dp" />

        <!-- Versi Aplikasi -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/md_theme_light_onPrimary"
            android:alpha="0.5" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Dialog Delete Activity (Modern)
    Deskripsi: Popup konfirmasi hapus item aktivitas/notifikasi
    Tombol delete menggunakan colorError agar terasa "destruktif"
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="10dp"
        android:text="@string/dialog_title_delete"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold" />

    <!-- Dialog Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:paddingBottom="24dp"
        android:text="@string/dialog_message_delete_activity"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Thin Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="24dp"
        android:alpha="0.12"
        android:background="?attr/colorOnSurface" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/button_cancel"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="?attr/colorOutlineVariant" />

        <!-- Delete Button — warna merah (colorError) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="?attr/colorError"
            android:text="@string/button_delete"
            android:textColor="?attr/colorOnError"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Profile Screen — WhatsApp Style (v4)
    - FAB edit DIHAPUS — avatar langsung bisa di-tap
    - BottomSheet untuk ganti foto (like SettingsFragment style)
    - Flat list rows tanpa card
    - Lottie & Shimmer dipertahankan
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_2"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ══ PROFILE CONTENT ══ -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollViewProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- ══ HEADER ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/color_2"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="36dp"
                    android:paddingBottom="20dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <!--
                        Avatar Container — clickable untuk buka BottomSheet
                        Overlay kamera muncul di sudut bawah kanan
                    -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layoutAvatarContainer"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        android:foreground="?attr/selectableItemBackground">

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieProfile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_profile_animation" />

                        <ImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_profile_picture"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/profile_border" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Nama -->
                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/linottesemibold"
                        android:text="@string/placeholder_name"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/text_color"
                        android:textStyle="bold" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.55"
                        android:fontFamily="@font/linottesemibold"
                        android:text="@string/placeholder_email"
                        android:textColor="?attr/text_color"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- ══ DIVIDER FULL ══ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:alpha="0.08"
                    android:background="?attr/text_color" />

                <!-- ══ SECTION LABEL ══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="24dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="4dp"
                    android:text="@string/header_personal_info"
                    android:fontFamily="@font/linottesemibold"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/text_color"
                    android:textStyle="bold"
                    android:alpha="0.55" />

                <!-- ══ ROW: Full Name ══ -->
                <LinearLayout
                    android:id="@+id/layoutEditName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_person"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.55"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/field_full_name"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/tvFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/placeholder_name"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Divider inset -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="68dp"
                    android:layout_marginEnd="30dp"
                    android:alpha="0.07"
                    android:background="?attr/text_color" />

                <!-- ══ ROW: Email ══ -->
                <LinearLayout
                    android:id="@+id/layoutEditEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_email"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.55"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/field_email"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/placeholder_email"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />
                    </LinearLayout>



                </LinearLayout>

                <!-- Divider inset -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="68dp"
                    android:layout_marginEnd="30dp"
                    android:alpha="0.07"
                    android:background="?attr/text_color" />

                <!-- ══ ROW: Birthday ══ -->
                <LinearLayout
                    android:id="@+id/layoutEditBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_cake"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.55"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/field_birthday"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/tvBirthday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/default_birthday"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />
                    </LinearLayout>



                </LinearLayout>

                <!-- Divider inset -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="68dp"
                    android:layout_marginEnd="30dp"
                    android:alpha="0.07"
                    android:background="?attr/text_color" />

                <!-- ══ ROW: Location ══ -->
                <LinearLayout
                    android:id="@+id/layoutEditLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        app:srcCompat="@drawable/ic_location"
                        app:tint="?attr/text_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.55"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/field_location"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/text_color" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/linottesemibold"
                            android:text="@string/default_location"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/text_color" />
                    </LinearLayout>



                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ══ SHIMMER LAYER ══ -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:shimmer_auto_start="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="36dp"
                    android:paddingBottom="20dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/color_4" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="150dp"
                        android:layout_height="27dp"
                        android:layout_marginBottom="9dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/color_3" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="14dp"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/color_3" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/color_4" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_4" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_3" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_3" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_3" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_3" />

            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

    </FrameLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Profile Screen (Modern - Fixed)
    Fix 1: FAB style diganti ke Widget.MaterialComponents.FloatingActionButton
    Fix 2: fabEditBg dipindah ke FrameLayout agar tidak overlap dengan konten
    Lottie: lottieProfile — DIPERTAHANKAN
    UPDATED: Shimmer diperbaiki dan hanya muncul saat load pertama
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_1"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="ExtraText">

        <!-- ── PROFILE CONTENT ── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollViewProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── PROFILE HEADER ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="@drawable/gradient_primary">

                    <!-- Background Image -->
                    <ImageView
                        android:id="@+id/ivBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/cd_profile_background"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <!-- Profile Center Content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Profile Image / Lottie Container -->
                        <RelativeLayout
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_marginBottom="14dp">

                            <!-- Lottie Default Profile — DIPERTAHANKAN -->
                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/lottieProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_centerInParent="true"
                                android:contentDescription="@string/cd_profile_animation" />

                            <ImageView
                                android:id="@+id/ivProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_centerInParent="true"
                                android:contentDescription="@string/cd_profile_picture"
                                android:scaleType="centerCrop"
                                android:visibility="gone" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/profile_border" />

                            <com.google.android.material.floatingactionbutton.FloatingActionButton
                                android:id="@+id/fabEditProfile"
                                style="@style/Widget.MaterialComponents.FloatingActionButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_alignParentBottom="true"
                                android:layout_marginEnd="-9dp"
                                android:layout_marginBottom="-7dp"
                                android:contentDescription="@string/cd_edit_profile_button"
                                android:src="@drawable/ic_edit"
                                app:backgroundTint="?attr/color_4"
                                app:fabCustomSize="32dp"
                                app:maxImageSize="16dp"
                                app:tint="?attr/text_color"
                                app:useCompatPadding="true" />

                        </RelativeLayout>

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_name"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="?attr/text_color"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.85"
                            android:text="@string/placeholder_email"
                            android:fontFamily="@font/linottesemibold"
                            android:textColor="?attr/text_color"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- fabEditBg di sini sebagai child langsung FrameLayout -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fabEditBg"
                        style="@style/Widget.MaterialComponents.FloatingActionButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:contentDescription="@string/cd_edit_background_button"
                        android:src="@drawable/ic_edit"
                        app:backgroundTint="?attr/color_4"
                        app:fabCustomSize="32dp"
                        app:maxImageSize="16dp"
                        app:tint="?attr/text_color"
                        app:useCompatPadding="true" />

                </FrameLayout>

                <!-- ── PERSONAL INFO CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="?attr/color_4"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="?attr/color_2">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:drawablePadding="10dp"
                            android:text="@string/header_personal_info"
                            android:fontFamily="@font/linottesemibold"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/text_color"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/ic_person_info"
                            app:drawableTint="?attr/text_color" />

                        <include
                            layout="@layout/item_profile_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── SHIMMER LAYER (DIPERBAIKI) ── -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone"
            app:shimmer_auto_start="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Skeleton: Header Background -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="?attr/color_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Skeleton Profile Picture -->
                        <View
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Skeleton Name -->
                        <View
                            android:layout_width="160dp"
                            android:layout_height="24dp"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Skeleton Email -->
                        <View
                            android:layout_width="120dp"
                            android:layout_height="16dp"
                            android:background="@drawable/shimmer_rounded" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Skeleton: Personal Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header -->
                        <View
                            android:layout_width="150dp"
                            android:layout_height="20dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Info Items -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/shimmer_rounded" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/shimmer_rounded" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/shimmer_rounded" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:background="@drawable/shimmer_rounded" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

    </FrameLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
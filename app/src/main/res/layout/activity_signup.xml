<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Sign Up Screen (Modern)
    Deskripsi: Tampilan pendaftaran akun baru
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        tools:ignore="ExtraText">

        <!-- ── Lottie Animation ── -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieAnimationViewSignUp"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="48dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

        <!-- ── Title ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/create_account_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/text_color"
            android:fontFamily="@font/linottebold"
            android:textStyle="bold" />

        <!-- ── Subtitle ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"
            android:text="@string/fill_details_to_sign_up"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/text_color"
            android:alpha="0.6"/>

        <!-- ── Form Fields ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="28dp"
            android:orientation="vertical">

            <!-- Username -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="?attr/color_yellow"
                app:endIconMode="clear_text"
                app:endIconTint="?attr/text_color"
                app:hintTextColor="?attr/color_yellow"
                app:boxBackgroundColor="?attr/color_2"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="?attr/color_4">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsernameSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/username_hint"
                    android:fontFamily="@font/linottesemibold"
                    android:inputType="text"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="?attr/text_color"
                    android:textColorHint="?attr/text_color" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Username Error -->
            <TextView
                android:id="@+id/tvUsernameError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/username_error_message"
                android:fontFamily="@font/linottesemibold"
                android:textColor="?attr/color_error"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="?attr/color_yellow"
                app:endIconMode="password_toggle"
                app:endIconTint="?attr/color_4"
                app:hintTextColor="?attr/color_yellow"
                app:boxBackgroundColor="?attr/color_2"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="?attr/color_4">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPasswordSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/password_hint"
                    android:fontFamily="@font/linottesemibold"
                    android:inputType="textPassword"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="?attr/text_color"
                    android:textColorHint="?attr/text_color" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Error -->
            <TextView
                android:id="@+id/tvPasswordError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/password_error_message"
                android:fontFamily="@font/linottesemibold"
                android:textColor="?attr/color_error"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Confirm Password -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="?attr/color_yellow"
                app:endIconMode="password_toggle"
                app:endIconTint="?attr/color_4"
                app:boxBackgroundColor="?attr/color_2"
                app:hintTextColor="?attr/color_yellow"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="?attr/color_4">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/confirm_password_hint"
                    android:fontFamily="@font/linottesemibold"
                    android:inputType="textPassword"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="?attr/text_color"
                    android:textColorHint="?attr/text_color" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password Error -->
            <TextView
                android:id="@+id/tvConfirmPasswordError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="@string/confirm_password_error_message"
                android:fontFamily="@font/linottesemibold"
                android:textColor="?attr/color_error"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Sign Up Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignUp"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/sign_up_button"
                android:fontFamily="@font/linottebold"
                android:textAllCaps="false"
                android:textColor="?attr/text_color"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="?attr/color_4"
                app:cornerRadius="14dp" />

            <!-- Login Link -->
            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="@string/already_have_account_signin"
                android:fontFamily="@font/linottesemibold"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/text_color"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
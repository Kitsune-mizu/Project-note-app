<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Modern Custom Confirmation Dialog (Simple)
    Deskripsi: Dialog konfirmasi modern tanpa icon, clean dan minimalis
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="10dp"
        android:text="@string/dialog_title_confirmation"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/text_color"
        android:textStyle="bold" />

    <!-- Dialog Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:paddingBottom="24dp"
        android:text="@string/dialog_message_are_you_sure"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/text_color"
        android:alpha="0.6"/>

    <!-- Thin Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="24dp"
        android:alpha="0.12"
        android:background="?attr/text_color" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Negative Button (No) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNegative"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/button_no"
            android:textColor="?attr/text_color"
            android:fontFamily="@font/linottesemibold"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="?attr/text_color"
            android:alpha="0.6"/>

        <!-- Positive Button (Yes) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPositive"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="?attr/color_4"
            android:text="@string/button_yes"
            android:fontFamily="@font/linottesemibold"
            android:textColor="?attr/text_color"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="8dp"
    android:background="?attr/color_1">

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/bubble_chat"
        android:src="@drawable/ic_chat_bubble"
        app:tint="?attr/text_color" />

    <TextView
        android:id="@+id/historyTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:textSize="14sp"
        android:fontFamily="@font/linottesemibold"
        android:textColor="?attr/text_color"
        android:maxLines="1"
        android:ellipsize="end"/>

    <ImageButton
        android:id="@+id/historyMoreBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_more_vert"
        android:background="?attr/color_1"
        android:contentDescription="@string/option"
        app:tint="?attr/text_color" />

</LinearLayout>
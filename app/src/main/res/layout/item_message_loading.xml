<?xml version="1.0" encoding="utf-8"?>
<!--
    Loading bubble: gemini_icon.png berputar + 3 titik berdenyut
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="16dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Avatar animasi: gemini_icon.png rotate -->
    <ImageView
        android:id="@+id/loadingIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/gemini_icon"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="@string/loading_please_wait"/>

    <!-- Bubble loading — shadow merata semua sisi -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginEnd="48dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="4dp"
        app:cardMaxElevation="4dp"
        app:strokeColor="#E8E8F0"
        app:strokeWidth="1dp">

        <!-- 3 titik berdenyut -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_dot_loading"/>

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_dot_loading"/>

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_loading"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Note Popup Menu (Modern)
    Background menggunakan bg_dialog_rounded_modern untuk konsistensi
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_menu_history"
    android:orientation="vertical"
    android:padding="8dp"
    tools:ignore="ExtraText">

    <!-- Reminder -->
    <LinearLayout
        android:id="@+id/action_reminder"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/cd_action_reminder"
            android:src="@drawable/ic_reminder"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/action_reminder_text"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/text_color" />
    </LinearLayout>

    <!-- Share -->
    <LinearLayout
        android:id="@+id/action_share"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/cd_action_share"
            android:src="@drawable/ic_share"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/action_share_note"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/text_color" />
    </LinearLayout>

    <!-- Thin divider sebelum Delete -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="4dp"
        android:background="?attr/color_4" />

    <!-- Delete -->
    <LinearLayout
        android:id="@+id/action_delete"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/cd_action_delete"
            android:src="@drawable/ic_delete"
            app:tint="?attr/color_error" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/action_delete_note"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/color_error"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
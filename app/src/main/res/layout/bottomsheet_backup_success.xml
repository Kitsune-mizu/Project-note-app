<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/color_2"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_sheet_handle" />

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:contentDescription="@null"
        app:srcCompat="@drawable/ic_check_circle"
        app:tint="?attr/color_green" />

    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/sheet_title_backup_success"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/text_color"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSuccessMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/sheet_msg_backup_success"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/text_color"
        android:alpha="0.7"
        android:lineSpacingMultiplier="1.4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_dialog_rounded"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_history"
            app:tint="?attr/text_color"
            android:alpha="0.5" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/label_last_backup"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/text_color"
            android:alpha="0.6" />

        <TextView
            android:id="@+id/tvLastBackupLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/backup_just_now"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/text_color"
            android:alpha="0.6" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="@string/action_done"
        android:textColor="?attr/text_color"
        android:fontFamily="@font/linottesemibold"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>
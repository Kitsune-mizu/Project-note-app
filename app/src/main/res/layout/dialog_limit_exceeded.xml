<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog: Rate Limit Harian (Gemini API)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="28dp"
    android:gravity="center">

    <!-- Icon Warning -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardBackgroundColor="?attr/color_2"
        app:cardElevation="0dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_warning_icon"
            android:src="@drawable/ic_warning"
            app:tint="#FF6D00" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/dialog_rate_limit_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/text_color"
        android:fontFamily="@font/linottesemibold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/dialog_rate_limit_message"
        android:fontFamily="@font/linottesemibold"
        android:alpha="0.6"
        android:textSize="14sp"
        android:textColor="?attr/text_color"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5" />

    <!-- Info Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_info_box"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_rate_limit_info_header"
            android:fontFamily="@font/linottesemibold"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/dialog_rate_limit_info_detail"
            android:fontFamily="@font/linottesemibold"
            android:textSize="12sp"
            android:textColor="?attr/text_color"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:text="@string/dialog_btn_understood"
        android:textColor="?attr/text_color"
        android:fontFamily="@font/linottesemibold"
        android:textSize="15sp"
        app:backgroundTint="?attr/color_4"
        app:cornerRadius="25dp" />

</LinearLayout>
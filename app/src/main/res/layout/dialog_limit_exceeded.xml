<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="28dp"
    android:gravity="center">

    <!-- Icon -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardBackgroundColor="#FFF3E0"
        app:cardElevation="0dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_warning"
            android:tint="#FF6D00"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Batas Harian Tercapai"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Anda telah mencapai batas 1.500 permintaan per hari untuk Gemini API Free Tier.\n\nBatas akan direset pada tengah malam (UTC+0)."
        android:textSize="14sp"
        android:textColor="#5A5A6E"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"/>

    <!-- Info box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_info_box"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Gemini API Free Tier:"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="• 15 permintaan per menit (RPM)\n• 1.000.000 token per menit (TPM)\n• 1.500 permintaan per hari (RPD)"
            android:textSize="12sp"
            android:textColor="#5A5A6E"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:text="Mengerti"
        android:textSize="15sp"
        app:backgroundTint="#6C63FF"
        app:cornerRadius="25dp"/>

</LinearLayout>
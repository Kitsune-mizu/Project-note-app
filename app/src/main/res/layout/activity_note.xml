<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Notes List Screen
    Deskripsi: Menampilkan daftar catatan dengan fitur pencarian,
    mode seleksi, dan tombol tambah catatan.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_surface">

    <!-- ================= APP BAR AREA ================= -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_light_surface"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|enterAlwaysCollapsed|exitUntilCollapsed"
            tools:ignore="ExtraText">

            <!-- Search View -->
            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:iconifiedByDefault="false"
                app:closeIcon="@drawable/transparent_icon"
                app:queryHint="@string/search_notes_hint" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ================= NOTES RECYCLER VIEW ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_notes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- ================= FLOATING ACTION BUTTON ================= -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/cd_add_new_note"
        android:src="@drawable/ic_add"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />

    <!-- ================= SELECTION MODE HEADER ================= -->
    <RelativeLayout
        android:id="@+id/selection_mode_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:visibility="gone">

        <!-- Cancel Selection Button -->
        <ImageButton
            android:id="@+id/action_cancel_selection"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_cancel_selection"
            android:src="@drawable/ic_close"
            app:tint="?attr/colorOnPrimary" />

        <!-- Selected Items Count -->
        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/action_cancel_selection"
            android:layout_toStartOf="@id/action_select_all"
            android:text="@string/selection_count_placeholder"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Select All Button -->
        <ImageButton
            android:id="@+id/action_select_all"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_select_all"
            android:src="@drawable/ic_select_all"
            app:tint="?attr/colorOnPrimary" />

    </RelativeLayout>

    <!-- ================= SELECTION MODE ACTION BAR ================= -->
    <LinearLayout
        android:id="@+id/selection_mode_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        android:baselineAligned="false"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <!-- Pin Action -->
        <ImageButton
            android:id="@+id/action_pin"
            style="@style/ActionIconStyle"
            android:layout_weight="1"
            android:contentDescription="@string/cd_pin_notes"
            android:src="@drawable/ic_pin_outline"
            app:tint="?attr/colorOnSurface" />

        <!-- Delete Action -->
        <ImageButton
            android:id="@+id/action_delete"
            style="@style/ActionIconStyle"
            android:layout_weight="1"
            android:contentDescription="@string/cd_delete_notes"
            android:src="@drawable/ic_delete"
            app:tint="?attr/colorError" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout Item: Note Card (Modern)
    cardElevation diturunkan, corner sedikit lebih besar
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/color_3"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/color_4"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:ignore="ExtraText">

        <ImageView
            android:id="@+id/btn_select_note"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="false"
            android:contentDescription="@string/cd_select_note"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:src="@drawable/ic_checkbox_off"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/text_color" />

        <ImageView
            android:id="@+id/iv_note_pin"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/cd_note_pinned"
            android:src="@drawable/ic_pin_filled"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/text_color" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="4dp"
            android:paddingEnd="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_note_pin"
            app:layout_constraintStart_toEndOf="@id/btn_select_note"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_note_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/note_title_placeholder"
                android:fontFamily="@font/linottesemibold"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/text_color"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_note_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.4"
                android:maxLines="3"
                android:text="@string/note_content_placeholder"
                android:fontFamily="@font/linottesemibold"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/text_color"
                android:alpha="0.6"/>

            <TextView
                android:id="@+id/tv_note_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/note_date_placeholder"
                android:fontFamily="@font/linottesemibold"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/text_color" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
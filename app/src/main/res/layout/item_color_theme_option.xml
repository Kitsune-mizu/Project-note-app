<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Color Preview Circles -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="16dp">

        <View
            android:id="@+id/colorPreview1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/circle_background" />

        <View
            android:id="@+id/colorPreview2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/circle_background" />

        <View
            android:id="@+id/colorPreview3"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/circle_background" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvColorThemeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/text_color" />

    <ImageView
        android:id="@+id/iconCheck"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:contentDescription="@string/desc_icon_check"
        app:srcCompat="@drawable/ic_check_circle"
        app:tint="?attr/text_color" />

</LinearLayout>
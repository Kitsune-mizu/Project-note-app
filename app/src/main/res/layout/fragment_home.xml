<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Home Screen (Modern)
    Deskripsi: Tampilan utama dengan SwipeRefresh, konten utama, dan shimmer loading
    Lottie: lottieWelcome (header), emptyActivity, emptyNotes — semua dipertahankan
    UPDATED: Shimmer diperbaiki dan hanya muncul saat load pertama
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="ExtraText">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ── MAIN CONTENT ── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollViewHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/color_1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── HEADER CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:cardBackgroundColor="@android:color/transparent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_primary">

                        <!-- Lottie Welcome Animation — DIPERTAHANKAN -->
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieWelcome"
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_marginTop="8dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Active Days Badge -->
                        <TextView
                            android:id="@+id/tvActiveDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_badge"
                            android:drawablePadding="6dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:singleLine="true"
                            android:text="@string/active_days_count"
                            android:fontFamily="@font/linottesemibold"
                            android:textColor="?attr/text_color"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/ic_fire"
                            app:drawableTint="?attr/text_color"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Greeting Container -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:layout_marginBottom="24dp"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:id="@+id/tvGreeting"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/greeting_morning"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvUsername"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:alpha="0.9"
                                android:text="@string/placeholder_username"
                                android:fontFamily="@font/linottesemibold"
                                android:textColor="?attr/text_color"
                                android:textSize="17sp" />

                            <TextView
                                android:id="@+id/tvDateTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:alpha="0.75"
                                android:text="@string/placeholder_datetime"
                                android:fontFamily="@font/linottesemibold"
                                android:textColor="?attr/text_color"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── RECENT ACTIVITY CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="?attr/color_4"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="?attr/color_2">

                        <!-- Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="10dp"
                                android:text="@string/header_recent_activity"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold"
                                app:drawableStartCompat="@drawable/ic_history"
                                app:drawableTint="?attr/text_color" />

                            <TextView
                                android:id="@+id/tvViewAll"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/button_view_all"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- RecyclerView Activity -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewActivities"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false" />

                        <!-- Empty Activity State — Lottie DIPERTAHANKAN -->
                        <LinearLayout
                            android:id="@+id/emptyActivity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="16dp"
                            android:visibility="gone">

                            <com.airbnb.lottie.LottieAnimationView
                                android:layout_width="110dp"
                                android:layout_height="110dp"
                                app:lottie_autoPlay="true"
                                app:lottie_loop="true"
                                app:lottie_rawRes="@raw/empty_activity" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/empty_state_no_activity"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── RECENT NOTES CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="?attr/color_4"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="?attr/color_2">

                        <!-- Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:drawablePadding="10dp"
                                android:text="@string/header_your_notes"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold"
                                app:drawableStartCompat="@drawable/ic_notes"
                                app:drawableTint="?attr/text_color" />

                            <TextView
                                android:id="@+id/tvViewAllNotes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/button_view_all"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- RecyclerView Notes -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false" />

                        <!-- Empty Notes State — Lottie DIPERTAHANKAN -->
                        <LinearLayout
                            android:id="@+id/emptyNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="16dp"
                            android:visibility="gone">

                            <com.airbnb.lottie.LottieAnimationView
                                android:layout_width="110dp"
                                android:layout_height="110dp"
                                app:lottie_autoPlay="true"
                                app:lottie_loop="true"
                                app:lottie_rawRes="@raw/empty_activity" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/empty_state_no_notes"
                                android:fontFamily="@font/linottesemibold"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textColor="?attr/text_color"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── SHIMMER OVERLAY (DIPERBAIKI) ── -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone"
            app:shimmer_auto_start="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Skeleton: Header Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="24dp">

                        <!-- Skeleton Lottie -->
                        <View
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Skeleton Text Lines -->
                        <View
                            android:layout_width="140dp"
                            android:layout_height="20dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <View
                            android:layout_width="100dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/shimmer_rounded" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Skeleton: Activity Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header -->
                        <View
                            android:layout_width="180dp"
                            android:layout_height="20dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Activity Items -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/shimmer_rounded" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/shimmer_rounded" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:background="@drawable/shimmer_rounded" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Skeleton: Notes Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/color_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header -->
                        <View
                            android:layout_width="150dp"
                            android:layout_height="20dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/shimmer_rounded" />

                        <!-- Notes Items -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="150dp"
                                android:layout_height="100dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/shimmer_rounded" />

                            <View
                                android:layout_width="150dp"
                                android:layout_height="100dp"
                                android:background="@drawable/shimmer_rounded" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

    </FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Map Selection Screen
    Deskripsi: Menampilkan peta, pencarian lokasi, dan tombol aksi bawah
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="ExtraText">

    <!-- ================= MAP VIEW ================= -->
    <org.osmdroid.views.MapView
        android:id="@+id/osm_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ================= TOP SEARCH SECTION ================= -->
    <!-- Container: Search Bar + Suggestions + Selected Location -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="16dp"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <!-- Search Input Container with Rounded Border -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_search_rounded"
            android:orientation="horizontal"
            android:padding="2dp">

            <!-- Search EditText -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="postalAddress"
                android:background="@android:color/transparent"
                android:drawablePadding="8dp"
                android:drawableStart="@drawable/ic_search"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/md_theme_light_onSurface"
                android:textColorHint="@color/md_theme_light_onSurface" />
        </LinearLayout>

        <!-- Suggestions List (RecyclerView) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestions"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_border"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Selected Location Display Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_border"
            android:orientation="vertical"
            android:padding="2dp">

            <!-- Shimmer Effect for Loading Location -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:shimmer_auto_start="false"
                app:shimmer_base_alpha="0.7"
                app:shimmer_dropoff="0.5"
                app:shimmer_duration="1000">

                <!-- Selected Location Text -->
                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:paddingVertical="12dp"
                    android:text="@string/determining_location"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textSize="16sp" />
            </com.facebook.shimmer.ShimmerFrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ================= BOTTOM ACTION BUTTONS ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/md_theme_light_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- My Location Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/my_location"
            android:textColor="@color/md_theme_light_onPrimary"
            app:backgroundTint="@color/md_theme_light_primary"
            app:cornerRadius="50dp" />

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/button_cancel"
            android:textColor="@color/md_theme_light_surface"
            app:backgroundTint="@color/md_theme_light_onSurface"
            app:cornerRadius="50dp" />

        <!-- Confirm / Select Location Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_location"
            android:textColor="@color/md_theme_light_onSecondary"
            app:backgroundTint="@color/md_theme_light_secondary"
            app:cornerRadius="50dp" />

    </LinearLayout>

</FrameLayout>
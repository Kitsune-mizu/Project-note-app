<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Map Selection Screen (Modern)
    Search bar, suggestions, location shimmer, dan bottom action buttons diperbarui
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="ExtraText">

    <!-- ── MAP VIEW ── -->
    <org.osmdroid.views.MapView
        android:id="@+id/osm_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── TOP SEARCH SECTION ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <!-- Search Bar -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:boxBackgroundColor="?attr/color_3"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeWidth="0dp"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_location"
            app:startIconTint="?attr/text_color">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="postalAddress"
                android:background="@null"
                android:hint="@string/search_hint"
                android:fontFamily="@font/linottesemibold"
                android:inputType="text"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="?attr/text_color"
                android:textColorHint="?attr/text_color" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Suggestions RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestions"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_dialog_rounded"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Location Display with Shimmer -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_dialog_rounded"
            android:paddingHorizontal="16dp"
            app:shimmer_auto_start="false"
            app:shimmer_base_alpha="0.7"
            app:shimmer_dropoff="0.5"
            app:shimmer_duration="1000">

            <TextView
                android:id="@+id/tvLocationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:paddingVertical="14dp"
                android:text="@string/determining_location"
                android:fontFamily="@font/linottesemibold"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/text_color"
                app:strokeColor="?attr/text_color"/>

        </com.facebook.shimmer.ShimmerFrameLayout>

    </LinearLayout>

    <!-- ── BOTTOM ACTION BUTTONS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_keyboard_toolbar"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyLocation"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/my_location"
            android:textColor="?attr/text_color"
            android:fontFamily="@font/linottesemibold"
            android:textStyle="bold"
            android:backgroundTint="?attr/color_4"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_location"
            app:iconTint="?attr/text_color"
            app:iconPadding="6dp"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:textColor="?attr/text_color"
            android:text="@string/button_cancel"
            android:fontFamily="@font/linottesemibold"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:strokeColor="?attr/text_color" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="?attr/color_4"
            android:text="@string/select_location"
            android:fontFamily="@font/linottesemibold"
            android:textColor="?attr/text_color"
            android:textStyle="bold"
            app:cornerRadius="14dp" />

    </LinearLayout>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Navigation Drawer Header (Modern)
    Lottie: lottieProfileNav — DIPERTAHANKAN
    Layout: foto/lottie di kiri, nama + email di kanan (horizontal)
    Fix   : tvUserEmail selalu tampil; guest pakai @string/placeholder_guest_email
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/nav_header_gradient"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="36dp"
    android:paddingBottom="20dp"
    tools:ignore="ExtraText">

    <!-- Dekorasi pattern pojok kanan atas -->
    <ImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:alpha="0.10"
        android:contentDescription="@null"
        android:src="@drawable/ic_pattern_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── FOTO / LOTTIE ── -->
    <FrameLayout
        android:id="@+id/profileContainer"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Lottie default profile — DIPERTAHANKAN -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieProfileNav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/profile_animation" />

        <!-- Photo (gone by default, shown when user has photo) -->
        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_profile_image"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Border ring overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/profile_border" />

        <!-- Online dot -->
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="1dp"
            android:layout_marginBottom="1dp"
            android:background="@drawable/online_indicator"
            android:elevation="2dp" />
    </FrameLayout>

    <!-- ── NAMA + EMAIL ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/profileContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/profileContainer"
        app:layout_constraintTop_toTopOf="@id/profileContainer">

        <!-- Nama / username -->
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/placeholder_name"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/md_theme_light_onPrimary"
            android:textStyle="bold" />

        <!--
            Email — SELALU tampil.
            Guest: setText(R.string.placeholder_guest_email) dari Java.
            Login: setText(email) dari profil.
        -->
        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:alpha="0.80"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/placeholder_email"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/md_theme_light_onPrimary" />
    </LinearLayout>

    <!-- ── DIVIDER ── -->
    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:alpha="0.18"
        android:background="@color/md_theme_light_onPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileContainer" />

    <!-- ── STATUS BADGE ROW ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider">

        <!-- Gemini quick-access chip -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:drawablePadding="5dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/menu_title_gemini"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/md_theme_light_onPrimary"
            app:drawableStartCompat="@drawable/ic_gemini" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
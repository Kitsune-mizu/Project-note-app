<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog: Simpan Respon AI sebagai Catatan
    User bisa edit judul sebelum menyimpan. Preview konten di-scroll.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="22dp"
    android:paddingBottom="20dp">

    <!-- Header: ikon + judul dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="18dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardBackgroundColor="#EEF2FF"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_save_note"
                android:contentDescription="@null"
                app:tint="#6C63FF" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_save_note_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_save_note_subtitle"
                android:textSize="12sp"
                android:textColor="#9090B0"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Input judul catatan -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_note_title"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="#F5F5FC"
        app:boxStrokeColor="#6C63FF"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Preview isi respon (scrollable) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#F8F8FF"
        app:cardElevation="0dp"
        app:strokeColor="#EAEAF5"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="110dp">

            <TextView
                android:id="@+id/previewNoteContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="12.5sp"
                android:textColor="#5A5A7A"
                android:lineSpacingMultiplier="1.4"/>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Info: konten akan disimpan apa adanya -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/dialog_save_note_info"
        android:textSize="11sp"
        android:textColor="#BBBBCC"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_warning"
        android:drawablePadding="5dp"
        app:drawableTint="#BBBBCC"/>

    <!-- Tombol aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveNoteCancel"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/action_cancel"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#EFEFFA"
            app:cornerRadius="23dp"
            android:textColor="#6C63FF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveNoteConfirm"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/action_save_note"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            app:backgroundTint="#6C63FF"
            app:cornerRadius="23dp"/>

    </LinearLayout>

</LinearLayout>
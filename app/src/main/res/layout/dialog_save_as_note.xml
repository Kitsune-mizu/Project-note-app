<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog: Simpan Respon AI sebagai Catatan
    User bisa edit judul sebelum menyimpan. Preview konten di-scroll.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="22dp"
    android:paddingBottom="20dp">

    <!-- Header: ikon + judul dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="18dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardBackgroundColor="?attr/color_2"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_save_note"
                android:contentDescription="@null"
                app:tint="#6C63FF" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_save_note_title"
                android:fontFamily="@font/linottesemibold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/text_color"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_save_note_subtitle"
                android:fontFamily="@font/linottesemibold"
                android:textSize="12sp"
                android:textColor="?attr/text_color"
                android:layout_marginTop="2dp"
                android:alpha="0.6"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Input judul catatan -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_note_title"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusTopStart="14dp"
        app:boxStrokeColor="?attr/color_yellow"
        app:boxBackgroundColor="?attr/color_2"
        app:hintTextColor="?attr/color_yellow"
        app:expandedHintEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:textColor="?attr/text_color"
            android:textColorHint="?attr/text_color"
            android:fontFamily="@font/linottesemibold"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Preview isi respon (scrollable) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="?attr/color_2"
        app:cardElevation="0dp"
        app:strokeColor="?attr/text_color"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="110dp">

            <TextView
                android:id="@+id/previewNoteContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="12.5sp"
                android:textColor="?attr/text_color"
                android:fontFamily="@font/linottesemibold"
                android:lineSpacingMultiplier="1.4"/>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Info: konten akan disimpan apa adanya -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/dialog_save_note_info"
        android:fontFamily="@font/linottesemibold"
        android:textSize="11sp"
        android:textColor="?attr/text_color"
        android:gravity="center_vertical"
        android:drawablePadding="5dp"
        android:alpha="0.6"
        app:drawableStartCompat="@drawable/ic_warning"
        app:drawableTint="?attr/text_color"/>

    <!-- Tombol aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveNoteCancel"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/action_cancel"
            android:fontFamily="@font/linottesemibold"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"
            android:textColor="?attr/text_color"
            app:strokeColor="?attr/text_color"
            app:cornerRadius="23dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveNoteConfirm"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/action_save_note"
            android:fontFamily="@font/linottesemibold"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            android:textColor="?attr/text_color"
            app:backgroundTint="?attr/color_4"
            app:cornerRadius="23dp"/>

    </LinearLayout>

</LinearLayout>
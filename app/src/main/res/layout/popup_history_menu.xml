<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_menu_history"
    android:paddingVertical="6dp"
    android:elevation="8dp">

    <!-- Rename -->
    <LinearLayout
        android:id="@+id/menuRename"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="@null"
            app:tint="?attr/text_color"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/action_rename"
            android:fontFamily="@font/linottesemibold"
            android:textSize="14sp"
            android:textColor="?attr/text_color" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_marginHorizontal="12dp"
        android:background="?attr/color_4"/>

    <!-- Delete -->
    <LinearLayout
        android:id="@+id/menuDelete"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="@null"
            app:tint="?attr/color_error"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/action_delete"
            android:fontFamily="@font/linottesemibold"
            android:textSize="14sp"
            android:textColor="?attr/color_error" />
    </LinearLayout>

</LinearLayout>
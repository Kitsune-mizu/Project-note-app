<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout Item: Language Selector (Modern)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:layout_marginVertical="3dp"
    android:background="?attr/color_1"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:paddingHorizontal="14dp"
    tools:ignore="ExtraText">

    <TextView
        android:id="@+id/tvLanguageName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/text_color"
        tools:text="English" />

    <ImageView
        android:id="@+id/iconCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="10dp"
        android:contentDescription="@string/cd_selected_language"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone"
        app:tint="?attr/text_color" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgFlag"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/cd_language_flag"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleShape" />

</LinearLayout>
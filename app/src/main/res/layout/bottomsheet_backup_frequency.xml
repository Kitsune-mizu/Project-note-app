<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/color_2"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp"
        android:text="@string/title_backup_frequency"
        android:fontFamily="@font/linottesemibold"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/text_color"
        android:textStyle="bold" />

    <!-- Setiap hari -->
    <LinearLayout
        android:id="@+id/optionDaily"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_schedule"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/freq_daily"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/text_color" />

        <ImageView
            android:id="@+id/iconCheckDaily"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_check_circle"
            app:tint="?attr/text_color" />

    </LinearLayout>

    <!-- Setiap minggu -->
    <LinearLayout
        android:id="@+id/optionWeekly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_schedule"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/freq_weekly"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/text_color" />

        <ImageView
            android:id="@+id/iconCheckWeekly"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_check_circle"
            app:tint="?attr/text_color" />

    </LinearLayout>

    <!-- Setiap bulan -->
    <LinearLayout
        android:id="@+id/optionMonthly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_schedule"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/freq_monthly"
            android:fontFamily="@font/linottesemibold"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/text_color" />

        <ImageView
            android:id="@+id/iconCheckMonthly"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_check_circle"
            app:tint="?attr/text_color" />

    </LinearLayout>

</LinearLayout>